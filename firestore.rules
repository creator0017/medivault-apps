rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── USER PROFILES (private) ───────────────────────────────────────────
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // Reports subcollection — owner + authorized family viewers
      match /reports/{reportId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.get("authorizedViewers", []);
      }

      // AI analyses — owner + authorized family viewers
      match /aiAnalyses/{analysisId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.get("authorizedViewers", []);
      }

      // Emergency card — owner + authorized family viewers (full/emergency permission)
      match /emergencyCard/{document=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
        allow read: if request.auth != null
          && request.auth.uid in get(/databases/$(database)/documents/users/$(userId)).data.get("authorizedViewers", []);
      }

      // Health reports — owner only
      match /healthReports/{reportId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Access logs — owner only
      match /accessLogs/{logId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // Notifications — owner reads/deletes, any authenticated family member can write
      match /notifications/{notifId} {
        allow read, delete, update: if request.auth != null && request.auth.uid == userId;
        allow create: if request.auth != null
          && request.resource.data.fromUid == request.auth.uid;
      }
    }

    // ─── PUBLIC PROFILES (for family member search) ────────────────────────
    match /publicProfiles/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ─── FAMILY REQUESTS ───────────────────────────────────────────────────
    match /familyRequests/{requestId} {
      allow create: if request.auth != null
                    && request.resource.data.fromUid == request.auth.uid;
      allow read: if request.auth != null
                  && (resource.data.fromUid == request.auth.uid
                      || resource.data.toUid == request.auth.uid);
      allow update: if request.auth != null
                    && resource.data.toUid == request.auth.uid;
      allow delete: if request.auth != null
                    && (resource.data.fromUid == request.auth.uid
                        || resource.data.toUid == request.auth.uid);
    }

    // ─── EMERGENCY SHARES ──────────────────────────────────────────────────
    match /emergencyShares/{shareId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // ─── DENY EVERYTHING ELSE ──────────────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
